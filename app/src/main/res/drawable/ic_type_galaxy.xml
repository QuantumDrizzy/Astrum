<?xml version="1.0" encoding="utf-8"?>
<!-- Spiral galaxy: two overlapping ellipses with bright nucleus -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="20dp" android:height="20dp"
    android:viewportWidth="24" android:viewportHeight="24">

    <!-- Horizontal ellipse (galaxy disc) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#4FC3F7"
        android:strokeWidth="1.6"
        android:pathData="M4,12 a8,2.8 0,1,0 16,0 a8,2.8 0,1,0 -16,0"/>

    <!-- Vertical ellipse (galaxy arms, tilted) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#4FC3F7"
        android:strokeWidth="1.6"
        android:pathData="M9.2,4 a2.8,8 0,1,0 5.6,0 a2.8,8 0,1,0 -5.6,0"/>

    <!-- Bright nucleus -->
    <path
        android:fillColor="#4FC3F7"
        android:pathData="M10.5,12 a1.5,1.5 0,1,0 3,0 a1.5,1.5 0,1,0 -3,0"/>
</vector>
