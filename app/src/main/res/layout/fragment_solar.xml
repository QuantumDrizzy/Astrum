<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <com.astrum.app.views.StarFieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingHorizontal="14dp"
            android:paddingBottom="20dp">

            <!-- SOL section -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/sun" style="@style/Astrum.SectionHeader"/>

            <!-- Alt / Az / Day length -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvSunAlt" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textColor="@color/amber" android:text="--°"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/altitude"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginHorizontal="4dp">
                    <TextView android:id="@+id/tvSunAz" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:text="--°"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/azimuth"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvSunDayLen" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--h --m"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/day_length"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Arc progress -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg" android:padding="12dp" android:layout_marginBottom="8dp">
                <ProgressBar
                    android:id="@+id/sunArcProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressTint="@color/amber"
                    android:progressBackgroundTint="@color/bg_surface"
                    android:max="100" android:progress="50"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:id="@+id/tvSunRise" android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:textSize="12sp" android:textColor="@color/text_primary" android:text="--:--"/>
                    <TextView android:id="@+id/tvSunNoon" android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:textSize="12sp" android:textColor="@color/text_dim" android:gravity="center" android:text="--:--"/>
                    <TextView android:id="@+id/tvSunSet" android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:textSize="12sp" android:textColor="@color/text_primary" android:gravity="end" android:text="--:--"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Twilights + golden hour -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvAstroDawn" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/astro_dawn"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginHorizontal="4dp">
                    <TextView android:id="@+id/tvNautDawn" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/naut_dawn"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvGoldenHour" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:textColor="@color/amber" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/golden_hour"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvAstroDusk" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/astro_dusk"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginHorizontal="4dp">
                    <TextView android:id="@+id/tvNautDusk" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/naut_dusk"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvGoldenEnd" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:textColor="@color/amber" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/golden_end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- RA / Dec -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvSunRa" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="13sp" android:text="--h --m"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/sun_ra"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvSunDec" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="13sp" android:text="±--°"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/declination"/>
                </LinearLayout>
            </LinearLayout>

            <!-- LUNA section -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/moon" style="@style/Astrum.SectionHeader"/>

            <!-- Moon visual + phase name -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="@drawable/card_bg"
                android:padding="13dp" android:gravity="center_vertical" android:layout_marginBottom="8dp">

                <com.astrum.app.views.MoonView
                    android:id="@+id/moonView"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tvMoonPhase"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:textColor="@color/text_primary" android:textStyle="bold"
                        android:layout_marginBottom="4dp" android:text="---"/>
                    <TextView android:id="@+id/tvMoonIllum"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:textSize="13sp" android:textColor="@color/amber"
                        android:layout_marginBottom="3dp" android:text="--%"/>
                    <TextView android:id="@+id/tvMoonDist"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:textSize="11sp" android:textColor="@color/text_dim"
                        android:text="--- km"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvMoonRise" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/rise"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginHorizontal="4dp">
                    <TextView android:id="@+id/tvMoonSet" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/set_time"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvMoonAlt" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="14sp" android:text="--°"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/altitude"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tiempo sidéreo + JD -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/time_section" style="@style/Astrum.SectionHeader"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvLst" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="13sp" android:textColor="@color/amber" android:text="--:--:--"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/local_st"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:background="@drawable/card_bg" android:padding="11dp" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvJd" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Value" android:textSize="13sp" android:text="-------.---"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        style="@style/Astrum.Label" android:text="@string/julian_day"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
