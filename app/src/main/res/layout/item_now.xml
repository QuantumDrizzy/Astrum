<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg"
    android:layout_marginBottom="5dp"
    android:padding="0dp">

    <!-- Left visibility indicator bar -->
    <View
        android:id="@+id/visIndicator"
        android:layout_width="3dp"
        android:layout_height="0dp"
        android:background="@color/green_vis"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Type badge top-right -->
    <TextView
        android:id="@+id/tvItemType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/badge_galaxy"
        android:paddingHorizontal="7dp"
        android:paddingVertical="2dp"
        android:fontFamily="monospace"
        android:textSize="9sp"
        android:textColor="@color/blue_accent"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Name -->
    <TextView
        android:id="@+id/tvItemName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/visIndicator"
        app:layout_constraintEnd_toStartOf="@id/tvItemType"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvItemSub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingTop="2dp"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:textColor="@color/text_dim"
        app:layout_constraintStart_toEndOf="@id/visIndicator"
        app:layout_constraintEnd_toStartOf="@id/tvItemAlt"
        app:layout_constraintTop_toBottomOf="@id/tvItemName"/>

    <!-- Altitude (right) -->
    <TextView
        android:id="@+id/tvItemAlt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/green_vis"
        android:layout_marginEnd="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvItemType"
        app:layout_constraintBaseline_toBaselineOf="@id/tvItemSub"/>

    <!-- Azimuth -->
    <TextView
        android:id="@+id/tvItemAz"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingBottom="10dp"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:textColor="@color/amber"
        app:layout_constraintStart_toEndOf="@id/visIndicator"
        app:layout_constraintTop_toBottomOf="@id/tvItemSub"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
